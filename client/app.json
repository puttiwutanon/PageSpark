{
  "expo": {
    "name": "PageSpark",
    "slug": "client",
    "androidStatusBar": {
      "hidden": true
    },
    "androidNavigationBar": {
      "visible": "immersive"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/PageSpark_icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/PageSpark_icon.png",
        "backgroundImage": "./assets/PageSpark_icon.png",
        "monochromeImage": "./assets/PageSpark_icon.png"
      },
      "package": "com.puttiwutanon.client"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-video",
      [
        "expo-build-properties",
        {
          "android": {
            "ndkVersion": "27.1.12297006"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "89ee76d6-7c1e-4115-b570-1b82647d28dc"
      }
    }
  }
}
